# Fayda Jobs Environment Variables

# Database Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://faydajobs.com

# Telegram Bot Configuration
# Get your bot token from BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Your channel username (with @) or channel ID
TELEGRAM_CHANNEL_ID=@faydajobs

# Optional: Telegram Bot Debug Mode (set to "true" for development)
TELEGRAM_DEBUG=false
